{
  "schema_version": "1",
  "predicates": [
    {"path": "$.target.fragment_id", "type": "string", "in_set": ["PHercParis2Fr47"]},
    {"path": "$.target.scroll_id", "type": "string", "in_set": ["PHerc.Paris.2"]},
    {"path": "$.target.energy_keV", "type": "int", "in_set": [54, 70, 88]},
    {"path": "$.target.voxel_size_um", "type": "float", "in_range": [1.0, 10.0]},
    {"path": "$.target.volume_level", "type": "int", "in_range": [0, 10]},
    {"path": "$.target.axes[*]", "type": "string",
     "in_set": ["z", "y", "x"], "for_all": true},
    {"path": "$.target.dtype", "type": "string", "in_set": ["uint8", "uint16"]},
    {"path": "$.target.zarr_format", "type": "int", "in_set": [2, 3]},
    {"path": "$.target", "type": "object",
     "key_set_includes": ["fragment_id", "scroll_id", "energy_keV",
                          "voxel_size_um", "volume_level", "axes",
                          "dtype", "zarr_format"]},

    {"path": "$.ome_ngff.axes", "type": "list", "min_size": 3, "max_size": 5},
    {"path": "$.ome_ngff.axes[*].name", "type": "string",
     "in_set": ["z", "y", "x", "c", "t"], "for_all": true},
    {"path": "$.ome_ngff.axes[*].type", "type": "string",
     "in_set": ["space", "channel", "time"], "for_all": true},
    {"path": "$.ome_ngff.n_pyramid_levels", "type": "int", "in_range": [2, 12]},
    {"path": "$.ome_ngff.pyramid_paths[*]", "type": "string",
     "regex": "^[0-9]+$", "for_all": true},

    {"path": "$.volume.path", "type": "string", "regex": "^[0-9]+$"},
    {"path": "$.volume.shape", "type": "list", "min_size": 3, "max_size": 3},
    {"path": "$.volume.shape[*]", "type": "int",
     "in_range": [1, 100000], "for_all": true},
    {"path": "$.volume.dtype", "type": "string",
     "in_set": ["uint8", "uint16", "<u1", "<u2"]},
    {"path": "$.volume.chunks", "type": "list", "min_size": 3, "max_size": 3},
    {"path": "$.volume.chunks[*]", "type": "int",
     "in_range": [1, 2048], "for_all": true},
    {"path": "$.volume.zarr_format", "type": "int", "in_set": [2, 3]},
    {"path": "$.volume.dimension_separator", "type": "string", "in_set": ["/", "."]},
    {"path": "$.volume.fill_value", "type": "int", "in_range": [0, 65535]},
    {"path": "$.volume.compressor_id", "type": "string",
     "in_set": ["blosc", "zlib", "lz4", "zstd", "gzip", ""]},
    {"path": "$.volume.compressor_cname", "type": "string",
     "in_set": ["zstd", "lz4", "snappy", "zlib", "blosclz", "lz4hc", ""]},

    {"path": "$.sample.n_total", "type": "int", "in_range": [1, 1000000]},
    {"path": "$.sample.n_nonzero", "type": "int", "in_range": [0, 1000000]},
    {"path": "$.sample.min", "type": "int", "in_range": [0, 65535]},
    {"path": "$.sample.max", "type": "int", "in_range": [0, 65535]},
    {"path": "$.sample.mean", "type": "float", "in_range": [0, 65535]},
    {"path": "$.sample.nonzero_ratio", "type": "float", "in_range": [0.5, 1.0]},

    {"path": "$.files", "type": "list", "min_size": 5, "max_size": 50},
    {"path": "$.files[*].file_path", "type": "string",
     "regex": "^fragment\\.zarr/", "for_all": true},
    {"path": "$.files[*].sha256_prefix", "type": "string",
     "regex": "^[0-9a-f]{16}$", "for_all": true},
    {"path": "$.files[*].size_bytes", "type": "int",
     "in_range": [10, 10000000], "for_all": true},

    {"path": "$.validation.all_validated", "type": "bool", "in_set": [true]},
    {"path": "$.validation.axes_names_match_target", "type": "bool", "in_set": [true]},
    {"path": "$.validation.axes_types_all_space", "type": "bool", "in_set": [true]},
    {"path": "$.validation.pyramid_paths_sequential", "type": "bool", "in_set": [true]},
    {"path": "$.validation.array_dtype_matches_target", "type": "bool", "in_set": [true]},
    {"path": "$.validation.array_chunks_cubic", "type": "bool", "in_set": [true]},
    {"path": "$.validation.zarr_format_matches_target", "type": "bool", "in_set": [true]},
    {"path": "$.validation.sample_has_real_data", "type": "bool", "in_set": [true]},
    {"path": "$.validation.sample_in_uint16_range", "type": "bool", "in_set": [true]},
    {"path": "$.validation.n_pyramid_levels", "type": "int", "in_range": [2, 12]},
    {"path": "$.validation.target_identifiers", "type": "list",
     "min_size": 3, "max_size": 20},
    {"path": "$.validation", "type": "object",
     "key_set_includes": ["all_validated", "axes_names_match_target",
                          "axes_types_all_space", "pyramid_paths_sequential",
                          "n_pyramid_levels", "array_dtype_matches_target",
                          "array_chunks_cubic", "zarr_format_matches_target",
                          "sample_has_real_data", "sample_in_uint16_range",
                          "n_files", "target_identifiers"]},

    {"path": "$.captured_from", "type": "string",
     "regex": "^https://dl\\.ash2txt\\.org/"},

    {"path": "$", "type": "object",
     "key_set_includes": ["target", "ome_ngff", "volume", "sample",
                          "files", "captured_from", "captured_at_utc",
                          "capture_method", "validation"]}
  ]
}
