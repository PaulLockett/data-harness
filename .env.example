# Hosted-API keys (any/all optional; harness falls back to local models if missing)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
VOYAGE_API_KEY=
COHERE_API_KEY=

# Daemon namespacing
DH_NAME=default
DH_SCRATCH_DIR=~/.data-harness

# Capabilities — declared profile (auto-detected if unset)
# DH_PROFILE=laptop-gpu
# DH_MODE=balanced            # latency | balanced | size | native | portable

# Storage budget (GB) — should_download() refuses weights that would breach this
# DH_STORAGE_BUDGET_GB=20

# Live resource ceiling (fraction; reserve 1 - this for the user)
# DH_LIVE_CEILING=0.40

# Model resolution overrides (optional; see spec §13 for defaults)
# DH_VLM_MODEL=Qwen/Qwen3-VL-8B-Instruct
# DH_LLM_MODEL=Qwen/Qwen3.5-9B-Instruct-AWQ
# DH_EMBED_MODEL=BAAI/bge-large-en-v1.5

# Force local even if API keys are present
# DH_FORCE_LOCAL=1

# Budget defaults
# DH_TASK_BUDGET_SECONDS=1800
# DH_TASK_DOLLAR_CAP=5.0
