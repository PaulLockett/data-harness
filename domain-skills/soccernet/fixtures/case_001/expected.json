{
  "schema_version": "1",
  "predicates": [
    {"path": "$.target.dataset", "type": "string", "in_set": ["SoccerNet-v2", "SoccerNet-v3"]},
    {"path": "$.target.task", "type": "string",
     "in_set": ["action-spotting", "replay-grounding", "tracking", "jersey-recognition"]},
    {"path": "$.target.n_primary_classes", "type": "int", "in_set": [17]},
    {"path": "$.target.team_classes", "type": "list", "min_size": 3, "max_size": 3},
    {"path": "$.target.team_classes[*]", "type": "string",
     "in_set": ["not applicable", "home", "away"], "for_all": true},
    {"path": "$.target.visibility_classes", "type": "list", "min_size": 3, "max_size": 3},
    {"path": "$.target.visibility_classes[*]", "type": "string",
     "in_set": ["not applicable", "visible", "not shown"], "for_all": true},
    {"path": "$.target.splits", "type": "list", "min_size": 4, "max_size": 4},
    {"path": "$.target.splits[*]", "type": "string",
     "in_set": ["train", "valid", "test", "challenge"], "for_all": true},
    {"path": "$.target", "type": "object",
     "key_set_includes": ["dataset", "task", "n_primary_classes",
                          "team_classes", "visibility_classes", "splits"]},

    {"path": "$.schema.n_primary_actions", "type": "int", "in_set": [17]},
    {"path": "$.schema.primary_actions", "type": "list", "min_size": 17, "max_size": 17},
    {"path": "$.schema.primary_actions[*]", "type": "string",
     "in_set": ["Penalty", "Kick-off", "Goal", "Substitution", "Offside",
                "Shots on target", "Shots off target", "Clearance",
                "Ball out of play", "Throw-in", "Foul",
                "Indirect free-kick", "Direct free-kick", "Corner",
                "Yellow card", "Red card", "Yellow->red card"],
     "for_all": true},
    {"path": "$.schema.team_classes[*]", "type": "string",
     "in_set": ["not applicable", "home", "away"], "for_all": true},
    {"path": "$.schema.visibility_classes[*]", "type": "string",
     "in_set": ["not applicable", "visible", "not shown"], "for_all": true},
    {"path": "$.schema.n_team_classes", "type": "int", "in_set": [3]},
    {"path": "$.schema.n_visibility_classes", "type": "int", "in_set": [3]},
    {"path": "$.schema.utils_has_getListGames", "type": "bool", "in_set": [true]},

    {"path": "$.files", "type": "list", "min_size": 4, "max_size": 4},
    {"path": "$.files[*].file_path", "type": "string",
     "in_set": ["classes.txt", "second_classes.txt", "third_classes.txt", "utils.py"],
     "for_all": true},
    {"path": "$.files[*].sha256_prefix", "type": "string",
     "regex": "^[0-9a-f]{16}$", "for_all": true},
    {"path": "$.files[*].size_bytes", "type": "int",
     "in_range": [10, 100000], "for_all": true},

    {"path": "$.validation.all_validated", "type": "bool", "in_set": [true]},
    {"path": "$.validation.n_action_classes_matches", "type": "bool", "in_set": [true]},
    {"path": "$.validation.teams_match_target", "type": "bool", "in_set": [true]},
    {"path": "$.validation.visibility_match_target", "type": "bool", "in_set": [true]},
    {"path": "$.validation.target_subset_in_actions", "type": "bool", "in_set": [true]},
    {"path": "$.validation.splits_in_utils", "type": "bool", "in_set": [true]},
    {"path": "$.validation.has_get_list_games", "type": "bool", "in_set": [true]},
    {"path": "$.validation.target_identifiers", "type": "list", "min_size": 5, "max_size": 20},
    {"path": "$.validation", "type": "object",
     "key_set_includes": ["all_validated", "n_action_classes_matches",
                          "teams_match_target", "visibility_match_target",
                          "target_subset_in_actions", "splits_in_utils",
                          "has_get_list_games", "n_files", "target_identifiers"]},

    {"path": "$.captured_from", "type": "string",
     "regex": "^https://raw\\.githubusercontent\\.com/SoccerNet/"},

    {"path": "$", "type": "object",
     "key_set_includes": ["target", "schema", "files", "captured_from",
                          "captured_at_utc", "capture_method", "validation"]}
  ]
}
