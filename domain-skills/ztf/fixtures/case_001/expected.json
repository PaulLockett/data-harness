{
  "schema_version": "1",
  "predicates": [
    {"path": "$.target.schemavsn", "type": "string", "in_set": ["3.3"]},
    {"path": "$.target.publisher", "type": "string",
     "in_set": ["ZTF (www.ztf.caltech.edu)"]},
    {"path": "$.target.programid", "type": "int", "in_set": [1]},
    {"path": "$.target.observation_night_utc", "type": "string",
     "regex": "^[0-9]{8}$"},
    {"path": "$.target", "type": "object",
     "key_set_includes": ["schemavsn", "publisher", "programid", "observation_night_utc"]},

    {"path": "$.alerts", "type": "list", "min_size": 1, "max_size": 50},

    {"path": "$.alerts[*].file_path", "type": "string",
     "regex": "^alerts/[0-9]+\\.avro$", "for_all": true},
    {"path": "$.alerts[*].size_bytes", "type": "int",
     "in_range": [10000, 1000000], "for_all": true},
    {"path": "$.alerts[*].sha256_prefix", "type": "string",
     "regex": "^[0-9a-f]{16}$", "for_all": true},
    {"path": "$.alerts[*].schema_name", "type": "string",
     "in_set": ["ztf.alert"], "for_all": true},
    {"path": "$.alerts[*].schemavsn", "type": "string",
     "in_set": ["3.3"], "for_all": true},
    {"path": "$.alerts[*].publisher", "type": "string",
     "in_set": ["ZTF (www.ztf.caltech.edu)"], "for_all": true},
    {"path": "$.alerts[*].objectId", "type": "string",
     "regex": "^ZTF[0-9]{2}[a-z]+$", "for_all": true},
    {"path": "$.alerts[*].object_id_matches_pattern", "type": "bool",
     "in_set": [true], "for_all": true},
    {"path": "$.alerts[*].n_top_fields", "type": "int",
     "in_range": [9, 12], "for_all": true},

    {"path": "$.alerts[*].candidate.fid", "type": "int",
     "in_set": [1, 2, 3], "for_all": true},
    {"path": "$.alerts[*].candidate.programid", "type": "int",
     "in_set": [1], "for_all": true},
    {"path": "$.alerts[*].candidate.ra", "type": "float",
     "in_range": [0, 360], "for_all": true},
    {"path": "$.alerts[*].candidate.dec", "type": "float",
     "in_range": [-90, 90], "for_all": true},
    {"path": "$.alerts[*].candidate.jd", "type": "float",
     "in_range": [2458000, 2470000], "for_all": true},
    {"path": "$.alerts[*].candidate.magpsf", "type": "float",
     "in_range": [10, 25], "for_all": true},
    {"path": "$.alerts[*].candidate.sigmapsf", "type": "float",
     "in_range": [0, 5], "for_all": true},
    {"path": "$.alerts[*].candidate.isdiffpos", "type": "string",
     "in_set": ["t", "f", "1", "0", "true", "false"], "for_all": true},
    {"path": "$.alerts[*].candidate.field", "type": "int",
     "in_range": [1, 2000], "for_all": true},

    {"path": "$.files", "type": "list", "min_size": 1, "max_size": 50},
    {"path": "$.files[*].file_path", "type": "string",
     "regex": "^alerts/[0-9]+\\.avro$", "for_all": true},
    {"path": "$.files[*].sha256_prefix", "type": "string",
     "regex": "^[0-9a-f]{16}$", "for_all": true},
    {"path": "$.files[*].size_bytes", "type": "int",
     "in_range": [10000, 1000000], "for_all": true},
    {"path": "$.files[*].format", "type": "string",
     "in_set": ["avro"], "for_all": true},

    {"path": "$.validation.all_validated", "type": "bool", "in_set": [true]},
    {"path": "$.validation.publishers_match_target", "type": "bool", "in_set": [true]},
    {"path": "$.validation.schemavsns_match_target", "type": "bool", "in_set": [true]},
    {"path": "$.validation.programids_match_target", "type": "bool", "in_set": [true]},
    {"path": "$.validation.object_ids_match_pattern", "type": "bool", "in_set": [true]},
    {"path": "$.validation.fids_in_ztf_filter_system", "type": "bool", "in_set": [true]},
    {"path": "$.validation.isdiffpos_valid", "type": "bool", "in_set": [true]},
    {"path": "$.validation.all_required_top_fields_present", "type": "bool", "in_set": [true]},
    {"path": "$.validation.all_required_candidate_fields_present", "type": "bool", "in_set": [true]},
    {"path": "$.validation.n_alerts", "type": "int", "in_range": [1, 50]},
    {"path": "$.validation.target_identifiers", "type": "list",
     "min_size": 3, "max_size": 20},
    {"path": "$.validation", "type": "object",
     "key_set_includes": ["all_validated", "publishers_match_target",
                          "schemavsns_match_target", "programids_match_target",
                          "object_ids_match_pattern", "fids_in_ztf_filter_system",
                          "isdiffpos_valid",
                          "all_required_top_fields_present",
                          "all_required_candidate_fields_present",
                          "n_alerts", "n_files", "target_identifiers"]},

    {"path": "$.captured_from", "type": "string",
     "regex": "^https://ztf\\.uw\\.edu/alerts/public/"},

    {"path": "$", "type": "object",
     "key_set_includes": ["target", "alerts", "files", "captured_from",
                          "captured_at_utc", "capture_method", "validation"]}
  ]
}
