{
  "schema_version": "1",
  "predicates": [
    {"path": "$.target.mmsi", "type": "int", "in_set": [303324000]},
    {"path": "$.target.vessel_name", "type": "string", "in_set": ["TAASINGE"]},
    {"path": "$.target.call_sign", "type": "string", "in_set": ["WDI7004"]},
    {"path": "$.target.vessel_type", "type": "int", "in_set": [30]},
    {"path": "$.target.country_mid", "type": "string", "in_set": ["303"]},
    {"path": "$.target.observation_date", "type": "string",
     "in_set": ["2024-01-01"]},
    {"path": "$.target", "type": "object",
     "key_set_includes": ["mmsi", "vessel_name", "call_sign", "vessel_type",
                          "country_mid", "observation_date"]},

    {"path": "$.vessel.mmsi", "type": "int", "in_set": [303324000]},
    {"path": "$.vessel.vessel_name", "type": "string", "in_set": ["TAASINGE"]},
    {"path": "$.vessel.call_sign", "type": "string",
     "regex": "^[WK][A-Z0-9]{3,7}$"},
    {"path": "$.vessel.vessel_type", "type": "int", "in_set": [30]},
    {"path": "$.vessel.imo", "type": "string", "regex": "^IMO[0-9]{7}$"},
    {"path": "$.vessel.transceiver_class", "type": "string", "in_set": ["A", "B"]},

    {"path": "$.tracks_summary.n_messages", "type": "int", "in_range": [10, 10000]},
    {"path": "$.tracks_summary.lat_min", "type": "float", "in_range": [-90, 90]},
    {"path": "$.tracks_summary.lat_max", "type": "float", "in_range": [-90, 90]},
    {"path": "$.tracks_summary.lat_min", "type": "float", "in_range": [44, 47]},
    {"path": "$.tracks_summary.lat_max", "type": "float", "in_range": [44, 47]},
    {"path": "$.tracks_summary.lon_min", "type": "float", "in_range": [-180, 180]},
    {"path": "$.tracks_summary.lon_max", "type": "float", "in_range": [-180, 180]},
    {"path": "$.tracks_summary.lon_min", "type": "float", "in_range": [-126, -122]},
    {"path": "$.tracks_summary.lon_max", "type": "float", "in_range": [-126, -122]},
    {"path": "$.tracks_summary.sog_min", "type": "float", "in_range": [0, 102.3]},
    {"path": "$.tracks_summary.sog_max", "type": "float", "in_range": [0, 102.3]},
    {"path": "$.tracks_summary.cog_min", "type": "float", "in_range": [0, 360]},
    {"path": "$.tracks_summary.cog_max", "type": "float", "in_range": [0, 360]},
    {"path": "$.tracks_summary.time_min", "type": "string",
     "regex": "^2024-01-01T"},
    {"path": "$.tracks_summary.time_max", "type": "string",
     "regex": "^2024-01-01T"},
    {"path": "$.tracks_summary.captured_dates[*]", "type": "string",
     "in_set": ["2024-01-01"], "for_all": true},

    {"path": "$.schema.n_columns", "type": "int", "in_set": [17]},
    {"path": "$.schema.columns[*]", "type": "string",
     "in_set": ["MMSI", "BaseDateTime", "LAT", "LON", "SOG", "COG", "Heading",
                "VesselName", "IMO", "CallSign", "VesselType", "Status",
                "Length", "Width", "Draft", "Cargo", "TransceiverClass"],
     "for_all": true},

    {"path": "$.files", "type": "list", "min_size": 1, "max_size": 5},
    {"path": "$.files[*].file_path", "type": "string",
     "regex": "^vessel_tracks\\.parquet$", "for_all": true},
    {"path": "$.files[*].sha256_prefix", "type": "string",
     "regex": "^[0-9a-f]{16}$", "for_all": true},
    {"path": "$.files[*].size_bytes", "type": "int",
     "in_range": [1000, 10000000], "for_all": true},
    {"path": "$.files[*].format", "type": "string",
     "in_set": ["parquet"], "for_all": true},
    {"path": "$.files[*].n_rows", "type": "int",
     "in_range": [10, 10000], "for_all": true},

    {"path": "$.validation.all_validated", "type": "bool", "in_set": [true]},
    {"path": "$.validation.all_mmsi_match_target", "type": "bool", "in_set": [true]},
    {"path": "$.validation.mmsi_starts_with_target_mid", "type": "bool", "in_set": [true]},
    {"path": "$.validation.vessel_name_matches_target", "type": "bool", "in_set": [true]},
    {"path": "$.validation.call_sign_matches_target", "type": "bool", "in_set": [true]},
    {"path": "$.validation.target_vessel_type_present", "type": "bool", "in_set": [true]},
    {"path": "$.validation.vessel_types_in_itu_table", "type": "bool", "in_set": [true]},
    {"path": "$.validation.sog_in_ais_range", "type": "bool", "in_set": [true]},
    {"path": "$.validation.cog_in_ais_range", "type": "bool", "in_set": [true]},
    {"path": "$.validation.heading_in_ais_range", "type": "bool", "in_set": [true]},
    {"path": "$.validation.lat_in_global_range", "type": "bool", "in_set": [true]},
    {"path": "$.validation.lon_in_global_range", "type": "bool", "in_set": [true]},
    {"path": "$.validation.all_dates_match_target", "type": "bool", "in_set": [true]},
    {"path": "$.validation.target_identifiers", "type": "list",
     "min_size": 5, "max_size": 20},
    {"path": "$.validation", "type": "object",
     "key_set_includes": ["all_validated", "all_mmsi_match_target",
                          "mmsi_starts_with_target_mid",
                          "vessel_name_matches_target",
                          "call_sign_matches_target",
                          "target_vessel_type_present",
                          "vessel_types_in_itu_table",
                          "sog_in_ais_range", "cog_in_ais_range",
                          "heading_in_ais_range",
                          "lat_in_global_range", "lon_in_global_range",
                          "all_dates_match_target",
                          "n_messages", "n_files", "target_identifiers"]},

    {"path": "$.captured_from", "type": "string",
     "regex": "^https://coast\\.noaa\\.gov/htdata/CMSP/AISDataHandler/"},

    {"path": "$", "type": "object",
     "key_set_includes": ["target", "vessel", "tracks_summary", "schema",
                          "files", "captured_from", "captured_at_utc",
                          "capture_method", "validation"]}
  ]
}
