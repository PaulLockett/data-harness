{
  "schema_version": "1",
  "predicates": [
    {"path": "$.target.dhs_country_code", "type": "string", "in_set": ["KE"]},
    {"path": "$.target.iso2_country_code", "type": "string", "in_set": ["KE"]},
    {"path": "$.target.iso3_country_code", "type": "string", "in_set": ["KEN"]},
    {"path": "$.target.country_name", "type": "string", "in_set": ["Kenya"]},
    {"path": "$.target.indicator_id", "type": "string", "in_set": ["FE_FRTR_W_TFR"]},
    {"path": "$.target.first_survey_id", "type": "string", "in_set": ["KE1989DHS"]},
    {"path": "$.target.first_survey_year", "type": "int", "in_set": [1989]},
    {"path": "$.target.first_survey_tfr", "type": "float", "in_range": [6.5, 7.0]},
    {"path": "$.target", "type": "object",
     "key_set_includes": ["dhs_country_code", "iso2_country_code",
                          "iso3_country_code", "country_name",
                          "indicator_id", "first_survey_id",
                          "first_survey_year", "first_survey_tfr"]},

    {"path": "$.country.dhs_country_code", "type": "string", "in_set": ["KE"]},
    {"path": "$.country.iso2_country_code", "type": "string",
     "regex": "^[A-Z]{2}$"},
    {"path": "$.country.iso3_country_code", "type": "string",
     "regex": "^[A-Z]{3}$"},
    {"path": "$.country.country_name", "type": "string", "in_set": ["Kenya"]},
    {"path": "$.country.region", "type": "string",
     "in_set": ["Sub-Saharan Africa", "South & Southeast Asia",
                "Latin America & Caribbean", "North Africa & West Asia",
                "Europe & Central Asia"]},
    {"path": "$.country.subregion", "type": "string",
     "in_set": ["Eastern Africa", "Western Africa", "Northern Africa",
                "Southern Africa", "Middle Africa", "South Asia",
                "Southeast Asia", "South America", "Central America",
                "Caribbean", "Western Asia", "Central Asia",
                "Eastern Europe"]},

    {"path": "$.indicator.indicator_id", "type": "string", "in_set": ["FE_FRTR_W_TFR"]},
    {"path": "$.indicator.label", "type": "string",
     "in_set": ["Total fertility rate 15-49"]},
    {"path": "$.indicator.measurement_type", "type": "string",
     "in_set": ["Rate", "Percentage", "Number", "Mean", "Median", "Ratio"]},
    {"path": "$.indicator.definition", "type": "string",
     "min_length": 30, "max_length": 600},

    {"path": "$.surveys_summary.n_surveys", "type": "int", "in_range": [5, 50]},
    {"path": "$.surveys_summary.first_survey_id", "type": "string",
     "in_set": ["KE1989DHS"]},
    {"path": "$.surveys_summary.first_survey_year", "type": "int", "in_set": [1989]},
    {"path": "$.surveys_summary.first_survey_org", "type": "string",
     "regex": "National Council for Population Development"},

    {"path": "$.first_survey_tfr.survey_id", "type": "string",
     "in_set": ["KE1989DHS"]},
    {"path": "$.first_survey_tfr.value", "type": "float", "in_range": [6.5, 7.0]},

    {"path": "$.files", "type": "list", "min_size": 4, "max_size": 4},
    {"path": "$.files[*].file_path", "type": "string",
     "in_set": ["indicator_data.json", "country.json",
                "surveys.json", "indicator_meta.json"], "for_all": true},
    {"path": "$.files[*].sha256_prefix", "type": "string",
     "regex": "^[0-9a-f]{16}$", "for_all": true},
    {"path": "$.files[*].size_bytes", "type": "int",
     "in_range": [100, 100000], "for_all": true},
    {"path": "$.files[*].format", "type": "string",
     "in_set": ["json"], "for_all": true},

    {"path": "$.validation.all_validated", "type": "bool", "in_set": [true]},
    {"path": "$.validation.dhs_cc_matches", "type": "bool", "in_set": [true]},
    {"path": "$.validation.iso2_matches", "type": "bool", "in_set": [true]},
    {"path": "$.validation.iso3_matches", "type": "bool", "in_set": [true]},
    {"path": "$.validation.name_matches", "type": "bool", "in_set": [true]},
    {"path": "$.validation.indicator_id_matches", "type": "bool", "in_set": [true]},
    {"path": "$.validation.indicator_label_contains_target", "type": "bool", "in_set": [true]},
    {"path": "$.validation.n_surveys_meets_min", "type": "bool", "in_set": [true]},
    {"path": "$.validation.first_survey_present", "type": "bool", "in_set": [true]},
    {"path": "$.validation.first_survey_year_matches", "type": "bool", "in_set": [true]},
    {"path": "$.validation.first_survey_org_matches", "type": "bool", "in_set": [true]},
    {"path": "$.validation.first_survey_tfr_matches", "type": "bool", "in_set": [true]},
    {"path": "$.validation.target_identifiers", "type": "list",
     "min_size": 5, "max_size": 20},
    {"path": "$.validation", "type": "object",
     "key_set_includes": ["all_validated", "dhs_cc_matches",
                          "iso2_matches", "iso3_matches", "name_matches",
                          "indicator_id_matches",
                          "indicator_label_contains_target",
                          "n_surveys_meets_min", "first_survey_present",
                          "first_survey_year_matches",
                          "first_survey_org_matches",
                          "first_survey_tfr_matches",
                          "n_files", "target_identifiers"]},

    {"path": "$.captured_from", "type": "string",
     "regex": "^https://api\\.dhsprogram\\.com/rest/dhs/"},

    {"path": "$", "type": "object",
     "key_set_includes": ["target", "country", "indicator",
                          "surveys_summary", "first_survey_tfr", "files",
                          "captured_from", "captured_at_utc",
                          "capture_method", "validation"]}
  ]
}
