{
  "schema_version": "1",
  "predicates": [
    {"path": "$.target.generated_unique_award_id", "type": "string",
     "in_set": ["CONT_AWD_80MSFC20C0034_8000_-NONE-_-NONE-"]},
    {"path": "$.target.piid", "type": "string", "in_set": ["80MSFC20C0034"]},
    {"path": "$.target.recipient_uei", "type": "string", "in_set": ["C6M7C2FLKER5"]},
    {"path": "$.target", "type": "object",
     "key_set_includes": ["generated_unique_award_id", "piid", "recipient_search", "recipient_uei"]},

    {"path": "$.award.generated_unique_award_id", "type": "string",
     "in_set": ["CONT_AWD_80MSFC20C0034_8000_-NONE-_-NONE-"]},
    {"path": "$.award.generated_unique_award_id", "type": "string",
     "regex": "^CONT_AWD_[A-Z0-9-]+_[0-9]+_[-A-Z0-9]+_[-A-Z0-9]+$"},
    {"path": "$.award.piid", "type": "string", "in_set": ["80MSFC20C0034"]},
    {"path": "$.award.piid", "type": "string", "regex": "^80MSFC[0-9]{2}[A-Z][0-9]{4}$"},
    {"path": "$.award.category", "type": "string",
     "in_set": ["contract", "grant", "loan", "direct payment", "other", "idv"]},
    {"path": "$.award.type", "type": "string",
     "in_set": ["A", "B", "C", "D", "E", "F", "G", "IDV_A", "IDV_B", "IDV_C"]},
    {"path": "$.award.type_description", "type": "string",
     "in_set": ["DEFINITIVE CONTRACT", "PURCHASE ORDER", "BPA CALL", "DELIVERY ORDER",
                "DEFINITIVE CONTRACT/ORDER"]},
    {"path": "$.award.total_obligation", "type": "float",
     "in_range": [2000000000, 5000000000]},
    {"path": "$.award.date_signed", "type": "string", "in_set": ["2020-05-13"]},
    {"path": "$.award.period_of_performance.start_date", "type": "string",
     "in_set": ["2020-05-13"]},
    {"path": "$.award.period_of_performance.last_modified_date", "type": "string",
     "regex": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    {"path": "$.award.description", "type": "string", "min_length": 50, "max_length": 5000},

    {"path": "$.recipient.recipient_name", "type": "string",
     "regex": "^SPACE EXPLORATION TECHNOLOGIES"},
    {"path": "$.recipient.recipient_uei", "type": "string", "in_set": ["C6M7C2FLKER5"]},
    {"path": "$.recipient.recipient_uei", "type": "string", "regex": "^[A-Z0-9]{12}$"},
    {"path": "$.recipient", "type": "object",
     "key_set_includes": ["recipient_name", "recipient_uei",
                          "parent_recipient_name", "parent_recipient_uei"]},

    {"path": "$.awarding_agency.toptier_name", "type": "string",
     "in_set": ["National Aeronautics and Space Administration"]},
    {"path": "$.awarding_agency.subtier_name", "type": "string",
     "regex": "^National Aeronautics and Space Administration"},

    {"path": "$.place_of_performance.city", "type": "string",
     "in_set": ["HAWTHORNE", "Hawthorne"]},
    {"path": "$.place_of_performance.state_code", "type": "string", "in_set": ["CA"]},
    {"path": "$.place_of_performance.state_name", "type": "string",
     "in_set": ["CALIFORNIA", "California"]},

    {"path": "$.files", "type": "list", "min_size": 1, "max_size": 5},
    {"path": "$.files[*].file_path", "type": "string",
     "regex": "^award\\.json$", "for_all": true},
    {"path": "$.files[*].sha256_prefix", "type": "string",
     "regex": "^[0-9a-f]{16}$", "for_all": true},
    {"path": "$.files[*].size_bytes", "type": "int",
     "in_range": [1000, 1000000], "for_all": true},
    {"path": "$.files[*].format", "type": "string",
     "in_set": ["json"], "for_all": true},

    {"path": "$.validation.all_validated", "type": "bool", "in_set": [true]},
    {"path": "$.validation.award_id_match", "type": "bool", "in_set": [true]},
    {"path": "$.validation.piid_match", "type": "bool", "in_set": [true]},
    {"path": "$.validation.recipient_name_contains_target", "type": "bool", "in_set": [true]},
    {"path": "$.validation.recipient_uei_match", "type": "bool", "in_set": [true]},
    {"path": "$.validation.awarding_toptier_is_nasa", "type": "bool", "in_set": [true]},
    {"path": "$.validation.description_mentions_hls", "type": "bool", "in_set": [true]},
    {"path": "$.validation.top_keys_match_api_spec", "type": "bool", "in_set": [true]},
    {"path": "$.validation.missing_top_keys", "type": "list", "max_size": 0},
    {"path": "$.validation.target_identifiers", "type": "list", "min_size": 3, "max_size": 20},
    {"path": "$.validation", "type": "object",
     "key_set_includes": ["all_validated", "award_id_match", "piid_match",
                          "recipient_name_contains_target", "recipient_uei_match",
                          "awarding_toptier_is_nasa", "description_mentions_hls",
                          "top_keys_match_api_spec", "n_files",
                          "target_identifiers"]},

    {"path": "$.captured_from", "type": "string",
     "regex": "^https://api\\.usaspending\\.gov/api/v2/awards/"},

    {"path": "$", "type": "object",
     "key_set_includes": ["target", "award", "recipient", "awarding_agency",
                          "place_of_performance", "files", "captured_from",
                          "captured_at_utc", "capture_method", "validation"]}
  ]
}
