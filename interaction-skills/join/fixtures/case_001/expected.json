{
  "schema_version": "1",
  "predicates": [
    {"path": "$.key", "type": "string", "in_set": ["id", "user_id", "facility_id", "key", "permit_id"]},
    {"path": "$.cardinality", "type": "string", "in_set": ["1:1", "1:N", "N:1", "N:M"]},
    {"path": "$.left_rows", "type": "int", "in_range": [1, 100000]},
    {"path": "$.right_rows", "type": "int", "in_range": [1, 100000]},
    {"path": "$.joined_rows", "type": "int", "in_range": [1, 100000]},
    {"path": "$.fanout_max", "type": "int", "in_range": [2, 100]},
    {"path": "$.missing_left", "type": "int", "in_range": [0, 100]},
    {"path": "$.missing_right", "type": "int", "in_range": [0, 100]},
    {"path": "$", "type": "object", "key_set_includes": ["key", "cardinality", "left_rows", "right_rows", "joined_rows", "fanout_max"]}
  ]
}
