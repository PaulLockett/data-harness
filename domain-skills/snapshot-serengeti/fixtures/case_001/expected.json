{
  "schema_version": "1",
  "predicates": [
    {"path": "$.target.dataset", "type": "string", "in_set": ["Snapshot Serengeti"]},
    {"path": "$.target.n_species_classes", "type": "int", "in_set": [61]},
    {"path": "$.target.n_seasons", "type": "int", "in_set": [11]},
    {"path": "$.target.top_species_by_count[*]", "type": "string",
     "min_length": 3, "for_all": true},
    {"path": "$.target.well_known_species[*]", "type": "string",
     "min_length": 3, "for_all": true},
    {"path": "$.target.splits[*]", "type": "string",
     "in_set": ["train", "val", "test"], "for_all": true},
    {"path": "$.target", "type": "object",
     "key_set_includes": ["dataset", "n_species_classes",
                          "top_species_by_count", "well_known_species",
                          "n_seasons", "splits"]},

    {"path": "$.species.n_classes", "type": "int", "in_set": [61]},
    {"path": "$.species.names", "type": "list", "min_size": 60, "max_size": 65},
    {"path": "$.species.names[*]", "type": "string",
     "min_length": 2, "for_all": true},
    {"path": "$.species.top_5_by_count", "type": "list",
     "min_size": 5, "max_size": 5},
    {"path": "$.species.top_5_by_count[*]", "type": "string",
     "in_set": ["empty", "wildebeest", "zebra", "gazellethomsons", "buffalo"],
     "for_all": true},
    {"path": "$.species.non_empty_top", "type": "string",
     "in_set": ["wildebeest"]},
    {"path": "$.species.non_empty_top_count", "type": "int",
     "in_range": [400000, 700000]},

    {"path": "$.splits.split_keys", "type": "list", "min_size": 2, "max_size": 2},
    {"path": "$.splits.split_keys[*]", "type": "string",
     "in_set": ["train", "val"], "for_all": true},
    {"path": "$.splits.n_train_sites", "type": "int", "in_range": [100, 500]},
    {"path": "$.splits.n_val_sites", "type": "int", "in_range": [10, 200]},
    {"path": "$.splits.train_sample[*]", "type": "string",
     "regex": "^[A-Z][0-9]{2}$", "for_all": true},
    {"path": "$.splits.val_sample[*]", "type": "string",
     "regex": "^[A-Z][0-9]{2}$", "for_all": true},

    {"path": "$.files", "type": "list", "min_size": 2, "max_size": 2},
    {"path": "$.files[*].file_path", "type": "string",
     "in_set": ["species_list.csv", "splits.json"], "for_all": true},
    {"path": "$.files[*].sha256_prefix", "type": "string",
     "regex": "^[0-9a-f]{16}$", "for_all": true},
    {"path": "$.files[*].size_bytes", "type": "int",
     "in_range": [100, 100000], "for_all": true},

    {"path": "$.validation.all_validated", "type": "bool", "in_set": [true]},
    {"path": "$.validation.n_species_matches", "type": "bool", "in_set": [true]},
    {"path": "$.validation.top_species_present", "type": "bool", "in_set": [true]},
    {"path": "$.validation.well_known_species_present", "type": "bool", "in_set": [true]},
    {"path": "$.validation.has_empty_class", "type": "bool", "in_set": [true]},
    {"path": "$.validation.has_wildebeest", "type": "bool", "in_set": [true]},
    {"path": "$.validation.splits_keys_match", "type": "bool", "in_set": [true]},
    {"path": "$.validation.train_sites_match_pattern", "type": "bool", "in_set": [true]},
    {"path": "$.validation.val_sites_match_pattern", "type": "bool", "in_set": [true]},
    {"path": "$.validation.n_train_sites_meets_min", "type": "bool", "in_set": [true]},
    {"path": "$.validation.wildebeest_is_top_non_empty", "type": "bool", "in_set": [true]},
    {"path": "$.validation.target_identifiers", "type": "list",
     "min_size": 5, "max_size": 30},
    {"path": "$.validation", "type": "object",
     "key_set_includes": ["all_validated", "n_species_matches",
                          "top_species_present",
                          "well_known_species_present",
                          "has_empty_class", "has_wildebeest",
                          "splits_keys_match",
                          "train_sites_match_pattern",
                          "val_sites_match_pattern",
                          "n_train_sites_meets_min",
                          "wildebeest_is_top_non_empty",
                          "n_files", "target_identifiers"]},

    {"path": "$.captured_from", "type": "string",
     "regex": "^https://lilawildlife\\.blob\\.core\\.windows\\.net/lila-wildlife/snapshotserengeti-"},

    {"path": "$", "type": "object",
     "key_set_includes": ["target", "species", "splits", "files",
                          "captured_from", "captured_at_utc",
                          "capture_method", "validation"]}
  ]
}
