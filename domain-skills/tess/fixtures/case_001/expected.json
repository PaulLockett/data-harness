{
  "schema_version": "1",
  "predicates": [
    {"path": "$.target.tic_id", "type": "string", "in_set": ["150428135"]},
    {"path": "$.target.tic_id", "type": "string", "regex": "^[0-9]{1,12}$"},
    {"path": "$.target.object_name", "type": "string", "regex": "^TIC\\s+[0-9]+$"},
    {"path": "$.target.tess_mag", "type": "float", "in_range": [0, 25]},
    {"path": "$.target.teff", "type": "float", "in_range": [2000, 12000]},
    {"path": "$.target.radius", "type": "float", "in_range": [0.05, 100]},
    {"path": "$.target.ra_deg", "type": "float", "in_range": [95, 100]},
    {"path": "$.target.dec_deg", "type": "float", "in_range": [-70, -60]},
    {"path": "$.target", "type": "object",
     "key_set_includes": ["tic_id", "object_name", "tess_mag", "teff", "radius", "ra_deg", "dec_deg", "camera", "ccd"]},

    {"path": "$.lightcurves", "type": "list", "min_size": 1, "max_size": 20},
    {"path": "$.lightcurves[*].file_path", "type": "string",
     "regex": "^lightcurves/.*\\.fits$", "for_all": true},
    {"path": "$.lightcurves[*].size_bytes", "type": "int",
     "in_range": [100000, 100000000], "for_all": true},
    {"path": "$.lightcurves[*].sha256_prefix", "type": "string",
     "regex": "^[0-9a-f]{16}$", "for_all": true},
    {"path": "$.lightcurves[*].sector", "type": "int",
     "in_range": [1, 100], "for_all": true},
    {"path": "$.lightcurves[*].n_cadences", "type": "int",
     "in_range": [100, 1000000], "for_all": true},
    {"path": "$.lightcurves[*].n_finite_flux", "type": "int",
     "in_range": [50, 1000000], "for_all": true},
    {"path": "$.lightcurves[*].time_min_bjd", "type": "float",
     "in_range": [1300, 100000], "for_all": true},
    {"path": "$.lightcurves[*].flux_column", "type": "string",
     "in_set": ["PDCSAP_FLUX", "SAP_FLUX"], "for_all": true},
    {"path": "$.lightcurves[*].tic_id_in_header", "type": "string",
     "regex": "^[0-9]{1,12}$", "for_all": true},
    {"path": "$.lightcurves[*].tic_id_match", "type": "bool",
     "in_set": [true], "for_all": true},
    {"path": "$.lightcurves[*].validated", "type": "bool",
     "in_set": [true], "for_all": true},
    {"path": "$.lightcurves[*].url", "type": "string",
     "regex": "^https://mast\\.stsci\\.edu/api/", "for_all": true},

    {"path": "$.validation.all_validated", "type": "bool", "in_set": [true]},
    {"path": "$.validation.n_lightcurves", "type": "int", "in_range": [1, 20]},
    {"path": "$.validation.target_identifiers", "type": "list",
     "min_size": 1, "max_size": 20},
    {"path": "$.validation", "type": "object",
     "key_set_includes": ["all_validated", "n_lightcurves", "target_identifiers"]},

    {"path": "$.captured_from", "type": "string",
     "regex": "^https://mast\\.stsci\\.edu/"},

    {"path": "$", "type": "object",
     "key_set_includes": ["target", "lightcurves", "captured_from", "captured_at_utc", "capture_method", "validation"]}
  ]
}
