{
  "schema_version": "1",
  "predicates": [
    {"path": "$", "type": "object",
     "key_set_includes": ["analysis","scope","totals","yearly_trend","top_builders_by_sites","top_builders_by_unenforced_violations","bmp_category_counts","regional","captured_from","document_archive","captured_at_utc","capture_method","documents_processed"]},

    {"path": "$.analysis", "type": "string", "min_length": 10, "max_length": 200},

    {"path": "$.scope.permit_prefix", "type": "string", "in_set": ["ALR10"]},
    {"path": "$.scope.media_area", "type": "string", "in_set": ["Air","Water","Land","Multi"]},
    {"path": "$.scope.date_start", "type": "string", "regex": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    {"path": "$.scope.date_end", "type": "string", "regex": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    {"path": "$.scope.years_covered", "type": "int", "in_range": [1, 50]},
    {"path": "$.scope", "type": "object",
     "key_set_includes": ["permit_prefix","media_area","date_start","date_end","years_covered"]},

    {"path": "$.totals", "type": "object",
     "key_set_includes": ["sites_started","sites_inspected","sites_with_cited_problem","sites_enforced","sites_unenforced_gap","inspections_processed","inspections_with_cited_problem"]},
    {"path": "$.totals.sites_started", "type": "int", "in_range": [100, 1000000]},
    {"path": "$.totals.sites_inspected", "type": "int", "in_range": [0, 1000000]},
    {"path": "$.totals.sites_with_cited_problem", "type": "int", "in_range": [0, 1000000]},
    {"path": "$.totals.sites_enforced", "type": "int", "in_range": [0, 1000000]},
    {"path": "$.totals.sites_unenforced_gap", "type": "int", "in_range": [0, 1000000]},
    {"path": "$.totals.inspections_processed", "type": "int", "in_range": [100, 10000000]},
    {"path": "$.totals.inspections_with_cited_problem", "type": "int", "in_range": [0, 10000000]},

    {"path": "$.yearly_trend", "type": "list", "min_size": 5, "max_size": 30},
    {"path": "$.yearly_trend[*].year", "type": "int", "in_range": [2009, 2030], "for_all": true},
    {"path": "$.yearly_trend[*].sites_started", "type": "int", "in_range": [0, 100000], "for_all": true},
    {"path": "$.yearly_trend[*].sites_inspected", "type": "int", "in_range": [0, 100000], "for_all": true},
    {"path": "$.yearly_trend[*].sites_cited_problem", "type": "int", "in_range": [0, 100000], "for_all": true},
    {"path": "$.yearly_trend[*].sites_enforced", "type": "int", "in_range": [0, 100000], "for_all": true},
    {"path": "$.yearly_trend[*].pct_inspected", "type": "float", "in_range": [0, 100], "for_all": true},
    {"path": "$.yearly_trend[*].pct_enforced", "type": "float", "in_range": [0, 100], "for_all": true},

    {"path": "$.top_builders_by_sites", "type": "list", "min_size": 5, "max_size": 50},
    {"path": "$.top_builders_by_sites[*].company", "type": "string", "min_length": 2, "for_all": true},
    {"path": "$.top_builders_by_sites[*].sites", "type": "int", "in_range": [1, 1000000], "for_all": true},
    {"path": "$.top_builders_by_sites[*].inspected", "type": "int", "in_range": [0, 1000000], "for_all": true},
    {"path": "$.top_builders_by_sites[*].cited_problem", "type": "int", "in_range": [0, 1000000], "for_all": true},
    {"path": "$.top_builders_by_sites[*].enforced", "type": "int", "in_range": [0, 1000000], "for_all": true},
    {"path": "$.top_builders_by_sites[*].unenforced_gap", "type": "int", "in_range": [0, 1000000], "for_all": true},

    {"path": "$.top_builders_by_unenforced_violations", "type": "list", "min_size": 1, "max_size": 50},
    {"path": "$.top_builders_by_unenforced_violations[*].company", "type": "string", "min_length": 2, "for_all": true},
    {"path": "$.top_builders_by_unenforced_violations[*].unenforced_gap", "type": "int", "in_range": [1, 1000000], "for_all": true},

    {"path": "$.bmp_category_counts", "type": "object",
     "key_set_includes": ["silt_fence","inlet_protection","gravel_entrance","vegetation","general_bmp"]},
    {"path": "$.bmp_category_counts.silt_fence", "type": "int", "in_range": [0, 1000000]},
    {"path": "$.bmp_category_counts.inlet_protection", "type": "int", "in_range": [0, 1000000]},
    {"path": "$.bmp_category_counts.gravel_entrance", "type": "int", "in_range": [0, 1000000]},
    {"path": "$.bmp_category_counts.vegetation", "type": "int", "in_range": [0, 1000000]},
    {"path": "$.bmp_category_counts.general_bmp", "type": "int", "in_range": [0, 1000000]},

    {"path": "$.regional", "type": "object", "key_set_includes": ["mobile_bay_watershed"]},
    {"path": "$.regional.mobile_bay_watershed", "type": "object",
     "key_set_includes": ["counties","sites_started","sites_inspected","sites_with_cited_problem","sites_enforced","sites_unenforced_gap","top_builders_by_sites","top_builders_by_unenforced"]},
    {"path": "$.regional.mobile_bay_watershed.counties", "type": "list", "min_size": 1, "max_size": 67},
    {"path": "$.regional.mobile_bay_watershed.counties[*]", "type": "string", "in_set": [
       "AUTAUGA","BALDWIN","BARBOUR","BIBB","BLOUNT","BULLOCK","BUTLER","CALHOUN",
       "CHAMBERS","CHEROKEE","CHILTON","CHOCTAW","CLARKE","CLAY","CLEBURNE","COFFEE",
       "COLBERT","CONECUH","COOSA","COVINGTON","CRENSHAW","CULLMAN","DALE","DALLAS",
       "DEKALB","ELMORE","ESCAMBIA","ETOWAH","FAYETTE","FRANKLIN","GENEVA","GREENE",
       "HALE","HENRY","HOUSTON","JACKSON","JEFFERSON","LAMAR","LAUDERDALE","LAWRENCE",
       "LEE","LIMESTONE","LOWNDES","MACON","MADISON","MARENGO","MARION","MARSHALL",
       "MOBILE","MONROE","MONTGOMERY","MORGAN","PERRY","PICKENS","PIKE","RANDOLPH",
       "RUSSELL","SHELBY","ST. CLAIR","SUMTER","TALLADEGA","TALLAPOOSA","TUSCALOOSA",
       "WALKER","WASHINGTON","WILCOX","WINSTON"
     ], "for_all": true},
    {"path": "$.regional.mobile_bay_watershed.sites_started", "type": "int", "in_range": [1, 1000000]},

    {"path": "$.captured_from", "type": "string", "regex": "^https://app\\.adem\\.alabama\\.gov/eFile/"},
    {"path": "$.document_archive", "type": "string", "regex": "^https://lf\\.adem\\.alabama\\.gov/WebLink/"},
    {"path": "$.captured_at_utc", "type": "string", "regex": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}.*Z?$"},
    {"path": "$.capture_method", "type": "string", "min_length": 20},

    {"path": "$.documents_processed", "type": "object",
     "key_set_includes": ["total_eFile_documents","inspr_documents_extracted","inspr_documents_unreachable"]},
    {"path": "$.documents_processed.total_eFile_documents", "type": "int", "in_range": [1, 100000000]},
    {"path": "$.documents_processed.inspr_documents_extracted", "type": "int", "in_range": [1, 100000000]},
    {"path": "$.documents_processed.inspr_documents_unreachable", "type": "int", "in_range": [0, 100000000]}
  ]
}
